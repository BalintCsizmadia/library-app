{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "NODE_ENV=development node ./server/app.ts",
    "start": "NODE_ENV=production node ./server/app.ts",
    "watch:dev": "nodemon",
    "test": "jest --coverage"
  },
  "nodemonConfig": {
    "exec": "npm run dev",
    "watch": [
      "server/*"
    ],
    "ignore": [
      "**/__tests__/**",
      "*.test.ts",
      "*.spec.ts"
    ]
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "ky": "^1.14.3",
    "dotenv": "^17.3.1",
    "koa": "^3.0.2",
    "koa-bodyparser": "^4.4.1",
    "koa-logger": "^4.0.0",
    "nodemon": "^3.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/koa": "^3.0.2",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-logger": "^3.1.5",
    "@types/koa__cors": "^5.0.1",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2"
  }
}
