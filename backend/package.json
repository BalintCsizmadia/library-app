{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "NODE_ENV=development node ./server/app.ts",
    "start": "NODE_ENV=production node ./server/app.ts",
    "watch:dev": "nodemon",
    "test": "jest --coverage"
  },
  "nodemonConfig": {
    "exec": "npm run dev",
    "watch": [
      "server/*"
    ],
    "ignore": [
      "**/__tests__/**",
      "*.test.ts",
      "*.spec.ts"
    ]
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.2",
    "ky": "^1.7.0",
    "dotenv": "^16.4.0",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.4.0",
    "koa-logger": "^3.2.1",
    "nodemon": "^3.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-logger": "^3.1.0",
    "@types/koa__cors": "^5.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
